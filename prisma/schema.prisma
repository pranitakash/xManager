// FC xManager — Production Prisma Schema
// PostgreSQL with JSONB for structured AI tool I/O

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User ───────────────────────────────────────────────
model User {
  id               String    @id @default(cuid())
  email            String    @unique
  subscriptionTier String    @default("free") // "free" | "pro" | "elite"
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sessions   Session[]
  executions Execution[]
  rateLimit  RateLimit?

  @@map("users")
}

// ─── Session ────────────────────────────────────────────
model Session {
  id        String   @id @default(cuid())
  userId    String
  mode      String   // "lab" | "boardroom"
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─── Execution ──────────────────────────────────────────
model Execution {
  id              String   @id @default(cuid())
  userId          String
  mode            String   // "lab" | "boardroom"
  tool            String   // tool identifier
  inputData       Json     // JSONB — structured input
  outputData      Json?    // JSONB — structured output (null while pending)
  executionTimeMs Int?     // milliseconds
  status          String   @default("pending") // "pending" | "processing" | "success" | "failed"
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, mode])
  @@index([status])
  @@map("executions")
}

// ─── RateLimit ──────────────────────────────────────────
model RateLimit {
  id           String   @id @default(cuid())
  userId       String   @unique
  requestCount Int      @default(0)
  lastReset    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rate_limits")
}
